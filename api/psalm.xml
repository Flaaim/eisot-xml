<?xml version="1.0"?>
<psalm
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns="https://getpsalm.org/schema/config"
    xsi:schemaLocation="https://getpsalm.org/schema/config vendor/vimeo/psalm/config.xsd"
    phpVersion="8.4"
    errorBaseline="psalm-baseline.xml"
    cacheDirectory="./var/cache/.psalm"
>
    <projectFiles>
        <directory name="src" />
        <ignoreFiles>
            <directory name="vendor" />
        </ignoreFiles>
    </projectFiles>
    <issueHandlers>
        <UnusedClass>
            <errorLevel type="suppress">
                <directory name="src/Data/Migration" />
                <directory name="src/Auth/Fixture" />
                <directory name="src/Http/Action" />
            </errorLevel>
        </UnusedClass>

        <MissingOverrideAttribute>
            <errorLevel type="suppress">
                <directory name="src" />
            </errorLevel>
        </MissingOverrideAttribute>

        <PossiblyUnusedMethod>
            <errorLevel type="suppress">
                <directory name="src/Auth/Test/Builder" />
                <directory name="src/Company/Test/Builder" />
                <directory name="src/OAuth/Test/Builder" />
                <directory name="src/Training/Test/Builder" />
                <directory name="src/Worker/Test/Builder" />

                <directory name="src/Training/Query/ExportRegistryToXml" />
                <directory name="src/Training/Query/GetRegistryRecords" />

                <directory name="src/Worker/Command/RegisterWorker" />
                <directory name="src/Training/Command/AttachRegistryNumber" />
                <directory name="src/Subscription/Query/CheckAccess" />
                <directory name="src/Company/Query/GetCompanyStats" />
                <directory name="src/Company/Query/GetCompany" />
                <directory name="src/Company/Command/RestoreCompany" />
                <directory name="src/Company/Command/ChangeCompanyInn" />
                <directory name="src/Company/Command/RenameCompany" />
                <directory name="src/Company/Command/ArchiveCompany" />
                <directory name="src/Company/Command/AddCompany" />
                <directory name="src/Auth/Command/AttachNetwork" />
                <directory name="src/Auth/Command/ChangeEmail" />
                <directory name="src/Auth/Command/ChangePassword" />
                <directory name="src/Auth/Command/ChangeRole" />
                <directory name="src/Auth/Command/JoinByEmail" />
                <directory name="src/Auth/Command/JoinByNetwork" />
                <directory name="src/Auth/Command/Remove" />
                <directory name="src/Auth/Command/ResetPassword" />
                <directory name="src/Training/Command/RecordTrainingResult" />
                <directory name="src/Subscription/Command/ActivateSubscription" />
                <directory name="src/Auth/Query/GetProfile" />
                <directory name="src/Subscription/Query/GetPaymentStatus" />
                <directory name="src/Subscription/Command/FailPayment" />
                <directory name="src/Subscription/Command/CreatePayment" />
                <directory name="src/Subscription/Command/ConfirmPayment" />
            </errorLevel>
        </PossiblyUnusedMethod>

    </issueHandlers>

    <plugins>
        <pluginClass class="Weirdan\DoctrinePsalmPlugin\Plugin" />
        <pluginClass class="Psalm\PhpUnitPlugin\Plugin" />
        <pluginClass class="Lctrs\PsalmPsrContainerPlugin\Plugin" />
    </plugins>
</psalm>
